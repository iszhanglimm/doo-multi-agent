# DOO多智能体系统环境变量配置

# ========== LLM 配置 ==========
# LLM提供商: openai | anthropic | custom
LLM_PROVIDER=openai

# API密钥（必填）
LLM_API_KEY=sk-your-api-key-here
# 或使用 OpenAI 专用密钥
# OPENAI_API_KEY=sk-your-api-key-here

# 自定义API端点（仅 custom 模式需要）
# LLM_BASE_URL=https://your-api-endpoint.com/v1

# 模型名称
LLM_MODEL=gpt-3.5-turbo

# 生成温度 (0.0-1.0)
LLM_TEMPERATURE=0.7

# 最大token数
LLM_MAX_TOKENS=2000

# ========== 存储配置 ==========
# 存储类型: json | sqlite
STORAGE_TYPE=json

# 数据存储路径
DATA_PATH=./data

# ========== Web服务器配置 ==========
# 服务器端口
PORT=3000
